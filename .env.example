# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── AI Provider (optional for MVP — app works without this) ──────────────────
# Set to "mock" to use deterministic mock AI, "anthropic" for real Claude API
EXPO_PUBLIC_AI_PROVIDER=mock

# Anthropic API key (only needed when AI_PROVIDER=anthropic)
# EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Set to "mock" to disable real analytics
EXPO_PUBLIC_ANALYTICS_PROVIDER=mock

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable AI-powered explanations (requires AI_PROVIDER != mock)
EXPO_PUBLIC_ENABLE_AI_EXPLANATIONS=false

# Set to "true" to enable schedule image import (OCR — not implemented in MVP)
EXPO_PUBLIC_ENABLE_SCHEDULE_OCR=false

# ── Build ─────────────────────────────────────────────────────────────────────
# App environment: "development" | "staging" | "production"
EXPO_PUBLIC_APP_ENV=development
