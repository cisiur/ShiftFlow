# ShiftFlow — Environment Variables Template
# Copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# ── Anthropic (AI plan explanations + Roster OCR) ─────────────────────────────
# Get your key at: https://console.anthropic.com/
# When set, AI explanations and roster import use Claude automatically.
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-api03-...

# ── RevenueCat (IAP) ─────────────────────────────────────────────────────────
# Get your Android key at: https://app.revenuecat.com/
# Use the Google Play public API key (not the secret key).
EXPO_PUBLIC_REVENUECAT_API_KEY=goog_...

# ── Feature flags (optional) ─────────────────────────────────────────────────
# Force a specific AI provider: 'anthropic' | 'mock'
# If unset, 'anthropic' is used automatically when ANTHROPIC_API_KEY is present.
# EXPO_PUBLIC_AI_PROVIDER=anthropic

# Enable feature flags explicitly (default: derived from key presence)
# EXPO_PUBLIC_ENABLE_AI_EXPLANATIONS=true
# EXPO_PUBLIC_ENABLE_SCHEDULE_OCR=true

# App environment: 'development' | 'staging' | 'production'
# EXPO_PUBLIC_APP_ENV=development
